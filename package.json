{
  "name": "@gapra/sdlc-planner-mcp",
  "version": "1.4.0",
  "description": "Principal-level AI Agents and Skills for SDLC Planning via MCP",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "sdlc-planner-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "agents",
    "skills",
    "examples",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sdlc",
    "ai-agents",
    "openapi",
    "feasibility-analysis",
    "planning",
    "claude",
    "cursor"
  ],
  "homepage": "https://www.npmjs.com/package/@gapra/sdlc-planner-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gapra/sdlc-planner-mcp.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint --fix \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"*.{json,md}\"",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run lint && npm test -- --run && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.6.0"
  }
}
